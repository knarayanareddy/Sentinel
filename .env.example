# Vultr core
VULTR_API_KEY=your_vultr_api_key_here
VULTR_BASE_URL=https://api.vultrinference.com/v1

# Reasoning models — TextGeneration models via Vultr Serverless Inference
# NOTE: VultronRetriever models are ReRank models, not chat completion models.
# Use TextGeneration models for all reasoning (planning, drift, MAARS, citations).
VULTRON_PRIME_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16
VULTRON_CORE_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16
VULTRON_FLASH_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Secondary model — non-core tasks only (optional)
SECONDARY_MODEL=deepseek-ai/DeepSeek-V4-Flash

# App behaviour
SENTINEL_ENV=demo
SANDBOX_EMAIL_SINK=mailhog

# Tuning
DRIFT_THRESHOLD=0.40
CITATION_THRESHOLD=0.60
MAARS_CONFIDENCE_MIN=70

# Deployment (set once on the Vultr VM)
PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=8000
